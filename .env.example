# Copy this file to .env and fill in real values before running docker compose.

# Generate a strong secret key:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-generate-a-strong-random-value

# Set a strong random password for the PostgreSQL database.
POSTGRES_PASSWORD=change-me-set-a-strong-password

# Set to your actual domain(s) in production (comma-separated, no wildcards).
ALLOWED_HOSTS=localhost
